{
  "name": "opchaves-web",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "db:generate": "dotenv -- drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply --local DB",
    "auth:db:generate": "LOCAL_DB_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) dotenv -- npx @better-auth/cli generate --output=\"database/auth-schema.ts\" --y",
    "db:migrate-production": "dotenv -- drizzle-kit migrate",
    "deploy": "CLOUDFLARE_ENV=production npm run build && wrangler deploy",
    "dev": "react-router dev --host 0.0.0.0",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b",
    "format": "prettier --write .",
    "test:e2e": "dotenv -e .env.test -- playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@uiw/react-md-editor": "^4.0.8",
    "better-auth": "^1.3.34",
    "drizzle-orm": "~0.44.7",
    "drizzle-seed": "^0.3.1",
    "github-markdown-css": "^5.8.1",
    "isbot": "^5.1.32",
    "kysely": "^0.28.8",
    "nanoid": "^5.1.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.5",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.14.0",
    "@playwright/test": "^1.56.1",
    "@react-router/dev": "^7.9.5",
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "better-sqlite3": "^12.4.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "~0.31.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.46.0"
  }
}
